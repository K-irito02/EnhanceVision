<RCC>
    <qresource prefix="/">
        <!-- QML 源文件 -->
        <file>../qml/main.qml</file>
        <file>../qml/App.qml</file>
        
        <!-- 页面组件 -->
        <file>../qml/pages/MainPage.qml</file>
        <file>../qml/pages/SettingsPage.qml</file>
        
        <!-- 通用组件 -->
        <file>../qml/components/Card.qml</file>
        <file>../qml/components/ControlPanel.qml</file>
        <file>../qml/components/FileList.qml</file>
        <file>../qml/components/MediaViewer.qml</file>
        <file>../qml/components/PreviewPane.qml</file>
        <file>../qml/components/Sidebar.qml</file>
        <file>../qml/components/TitleBar.qml</file>
        <file>../qml/components/SessionList.qml</file>
