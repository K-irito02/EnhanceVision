        <file>../qml/shaders/Vignette.qml</file>
        <file>../qml/shaders/Highlights.qml</file>
        <file>../qml/shaders/Shadows.qml</file>
        
        <!-- 样式定义 -->
        <file>../qml/styles/Theme.qml</file>
        <file>../qml/styles/Colors.qml</file>
        <file>../qml/styles/Typography.qml</file>
        
        <!-- 工具脚本 -->
        <file>../qml/utils/Helpers.js</file>
        <file>../qml/utils/ShortcutManager.qml</file>
    </qresource>
    
