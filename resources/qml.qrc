        <file>../qml/components/Toast.qml</file>
        <file>../qml/components/OffscreenShaderRenderer.qml</file>
        <file>../qml/components/MultiPassShaderEffect.qml</file>
        <file>../qml/components/SeparableBlurEffect.qml</file>
        <file>../qml/components/VideoPlaybackController.qml</file>
        
        <!-- 自定义控件 -->
        <file>../qml/controls/Button.qml</file>
        <file>../qml/controls/ComboBox.qml</file>
        <file>../qml/controls/IconButton.qml</file>
